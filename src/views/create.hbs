
        <section id="create-container">
            <div class="create-container-info">
                <h1>Create Blog</h1>
                {{#if error}}
                <div class="errorContainer">
                   <p>{{error}}</p>
                </div>
                {{/if}}
                <form action="/blogs/create" method="POST">
                    <label>Title:</label>
                    <input name="title" type="text" id="title">

                    <label>Image:</label>
                    <input name="image" type="text" id="image" placeholder="http://...">

                    <label>Content:</label>
                    <textarea id="content" name="content"></textarea>

                    <label>Blog Category:</label>
                    <input name="category" type="text" id="category">

                    <input type="submit" id="btn" value="Create">
                </form>
            </div>
        </section>
